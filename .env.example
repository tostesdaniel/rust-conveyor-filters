# Authentication (Required)
# Create a Clerk application at https://dashboard.clerk.dev
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_publishable_key
CLERK_SECRET_KEY=your_secret_key
CLERK_DASHBOARD_USER_URL_PREFIX=

# Authentication Routes and Fallbacks
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/my-filters
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/filters
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/my-filters
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/filters

# Database (Required)
# Create a database at https://neon.tech
DATABASE_URL=DATABASE_URL="postgresql://postgres:rcfisawesome@127.0.1.1:5433/postgres"


# Redis (Optional - won't use Redis in development if not provided)
# Only used for rate limiting events
# Create a Redis database at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Discord Integration (Not needed in development)
DISCORD_WEBHOOK_SECRET=
DISCORD_USER_COUNT_CHANNEL_ID=
DISCORD_FEEDBACK_CHANNEL_ID=
DISCORD_GUILD_ID=
DISCORD_TOKEN=
# Payment Integration (Not needed in development)
BMC_VERIFICATION_TOKEN=
KOFI_VERIFICATION_TOKEN=

# PayNow Billing (Required for subscription features)
# Dashboard: https://dashboard.paynow.gg
PAYNOW_API_KEY=
PAYNOW_STORE_ID=
PAYNOW_WEBHOOK_SECRET=
PAYNOW_PRODUCT_ID_MONTHLY=
PAYNOW_PRODUCT_ID_YEARLY=
# Feature flag to swap the /donate pricing UI to PayNow
NEXT_PUBLIC_PAYNOW_ENABLED=false

# Steam Integration (Not needed in development)
# Get your Steam API key at https://steamcommunity.com/dev/apikey
STEAM_ID=
STEAM_API_KEY=

# GitHub Integration (Not needed in development)
GITHUB_TOKEN=

# Public URLs (Not needed in development)
NEXT_PUBLIC_R2_BUCKET_URL=

# AI Filter Categorization (Optional)
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=
AI_CRON_SECRET=
AI_CATEGORIZATION_DISABLED=
# How many filters the worker processes per tick (default 10)
AI_CATEGORIZATION_BATCH_SIZE=10